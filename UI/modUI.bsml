<bg xmlns:xsi='http://www.w3.org/2001/XMLSchema-instance' xsi:noNamespaceSchemaLocation='https://monkeymanboy.github.io/BSML-Docs/BSMLSchema.xsd'>
    <vertical horizontal-fit='PreferredSize' vertical-fit='PreferredSize' preferred-width='90' spacing='0' anchor-max-y='1.35'>
        <toggle-setting value="enable" text="Full toggle" on-change='set_enabled' apply-on-change="true" hover-hint='Enable the mod'/>
        <slider-setting id='delay_slider' value ='delay_value' show-buttons='true' on-change='set_delay_value' apply-on-change='true' bind-value='true' text='Delay between shocks' increment='1' min='0' max='60' formatter='duration_slider_formatter'/>
        <toggle-setting value="enable_cs" text="Enable shock for combo break" on-change='set_cs_enabled' apply-on-change="true" hover-hint='Enable shock for combo break'/>
        <slider-setting id='intensity_slider' value ='intensity_value' show-buttons='true' on-change='set_intensity_value' apply-on-change='true' bind-value='true' text='Desired intensity' increment='1' min='0' max='100' formatter='intensity_slider_formatter'/>
        <slider-setting id='duration_slider' value ='duration_value' show-buttons='true' on-change='set_duration_value' apply-on-change='true' bind-value='true' text='Desired duration' increment='1' min='0' max='15' formatter='duration_slider_formatter'/>
    </vertical>
</bg>